    <script>
            function InicializarSelect2() {
                $('.select2').select2({
                    width: '100%'
                });
            }

            $(document).ready(function () {
                InicializarSelect2();
            });

            if (typeof (Sys) !== "undefined") {
                Sys.Application.add_load(function () {
                    InicializarSelect2();
                });
            }
    </script>

