    <script type="text/javascript">
        function showSuccessToast(message) {
            toastr.success(message, 'Sucesso');
        }
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "10000"
        };
        function showWarningToast(message) {
            toastr.warning(message, 'Atenção');
        }
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "10000"
        };
        function showErrorToast(message) {
            toastr.error(message, 'Erro');
        }
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "10000"
        };
        function showInfoToast(message) {
            toastr.info(message, 'Informativo');
        }
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "10000"
        };


        function showSuccessToastVeiculo(message) {
